#!ipxe

menu Bootforge Boot Menu
timeout 30000
default rescue

item rescue Rescue System
item ubuntu-install Ubuntu 24.04
item local-disk Boot from local disk

choose selected || goto failed

:rescue
kernel http://192.168.1.10:8080/tools/rescue/vmlinuz boot=live
initrd http://192.168.1.10:8080/tools/rescue/initrd
boot

:ubuntu-install
kernel http://192.168.1.10:8080/installers/ubuntu/vmlinuz autoinstall ds=nocloud
initrd http://192.168.1.10:8080/installers/ubuntu/initrd
boot

:local-disk
exit 0

:failed
echo Boot failed, retrying in 5 seconds...
sleep 5
goto start
